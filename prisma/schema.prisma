// Barakah — household money manager
// Money is ALWAYS stored as integer cents (Int). Divide by 100 only for display.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MEMBER
  VIEWER
}

enum AccountType {
  CASH
  BANK
  SAVINGS
  CREDIT_CARD
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum TxType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TxSource {
  MANUAL
  CSV
  API
}

enum BudgetPeriod {
  MONTHLY
}

enum AuthEventType {
  LOGIN
  LOGOUT
}

enum Cadence {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Household {
  id                  String    @id @default(cuid())
  name                String
  baseCurrency        String    @default("MAD")
  savingsMonthlyCents Int?
  savingsGoalDeadline DateTime?
  // Savings balance captured when the goal was set. Goal progress counts only
  // what's saved *after* this point, so money already set aside doesn't
  // pre-fill the bar.
  savingsGoalBaselineCents Int?
  createdAt           DateTime  @default(now())

  memberships    Membership[]
  accounts       Account[]
  categories     Category[]
  budgets        Budget[]
  recurringRules RecurringRule[]
  invites        Invite[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  locale       String   @default("en")
  createdAt    DateTime @default(now())

  memberships  Membership[]
  transactions Transaction[] @relation("EnteredBy")
  authEvents   AuthEvent[]
}

// Audit trail of sign-in / sign-out events, written from NextAuth events.
model AuthEvent {
  id        String        @id @default(cuid())
  userId    String
  email     String
  type      AuthEventType
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Membership {
  id          String @id @default(cuid())
  householdId String
  userId      String
  role        Role   @default(MEMBER)

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}

model Account {
  id           String      @id @default(cuid())
  householdId  String
  name         String
  type         AccountType @default(BANK)
  balanceCents Int         @default(0)
  currency     String      @default("MAD")
  // The household's main account (e.g. where salary lands). At most one per
  // household — the app clears the flag on others when a new primary is set.
  isPrimary    Boolean     @default(false)
  createdAt    DateTime    @default(now())

  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  recurringRules RecurringRule[]

  @@index([householdId])
}

model Category {
  id          String       @id @default(cuid())
  householdId String
  parentId    String?
  name        String
  kind        CategoryKind @default(EXPENSE)
  icon        String       @default("circle")

  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parent         Category?       @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]      @relation("CategoryChildren")
  transactions   Transaction[]
  budgets        Budget[]
  recurringRules RecurringRule[]

  @@index([householdId])
}

model Transaction {
  id              String   @id @default(cuid())
  accountId       String
  categoryId      String?
  enteredById     String
  recurringRuleId String?
  transferGroupId String?
  amountCents     Int
  type            TxType   @default(EXPENSE)
  date            DateTime
  note            String?
  source          TxSource @default(MANUAL)
  createdAt       DateTime @default(now())

  account       Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  enteredBy     User           @relation("EnteredBy", fields: [enteredById], references: [id])
  recurringRule RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([categoryId])
  @@index([date])
  @@index([transferGroupId])
}

model Budget {
  id          String       @id @default(cuid())
  householdId String
  categoryId  String
  limitCents  Int
  period      BudgetPeriod @default(MONTHLY)

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([householdId, categoryId, period])
  @@index([householdId])
}

model RecurringRule {
  id          String   @id @default(cuid())
  householdId String
  categoryId  String
  accountId   String
  amountCents Int
  type        TxType   @default(EXPENSE)
  cadence     Cadence  @default(MONTHLY)
  nextRun     DateTime
  note        String?
  createdAt   DateTime @default(now())

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([householdId])
}

model Invite {
  id          String   @id @default(cuid())
  householdId String
  email       String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, email])
}
